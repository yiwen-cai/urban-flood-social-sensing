{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiwen-cai/urban-flood-social-sensing/schemas/prediction.schema.json",
  "title": "Model prediction row keyed by (post_id, model_version)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pipeline_run_id",
    "post_id",
    "model_version",
    "predicted_label",
    "model_scores",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "pipeline_run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "post_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "model_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "predicted_label": {
      "oneOf": [
        {"type": "null"},
        {
          "enum": [
            "caution_and_advice",
            "displaced_people_and_evacuations",
            "infrastructure_and_utility_damage",
            "injured_or_dead_people",
            "not_humanitarian",
            "other_relevant_information",
            "requests_or_urgent_needs",
            "rescue_volunteering_or_donation_effort",
            "sympathy_and_support"
          ]
        }
      ]
    },
    "model_scores": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "caution_and_advice",
          "displaced_people_and_evacuations",
          "infrastructure_and_utility_damage",
          "injured_or_dead_people",
          "not_humanitarian",
          "other_relevant_information",
          "requests_or_urgent_needs",
          "rescue_volunteering_or_donation_effort",
          "sympathy_and_support"
        ]
      },
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "status": {"enum": ["ok", "error"]},
    "error_message": {"type": ["string", "null"], "maxLength": 2000},
    "confidence": {
      "oneOf": [
        {"type": "null"},
        {"type": "number", "minimum": 0, "maximum": 1}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "ok"}}, "required": ["status"]},
      "then": {
        "properties": {
          "predicted_label": {"type": "string"},
          "error_message": {"type": "null"}
        },
        "required": ["predicted_label"]
      }
    },
    {
      "if": {"properties": {"status": {"const": "error"}}, "required": ["status"]},
      "then": {
        "properties": {
          "predicted_label": {"type": "null"},
          "error_message": {"type": "string", "minLength": 1}
        }
      }
    }
  ]
}
