# Copy to `.env` locally. Never commit a real API key.
#
# Residual compliance risk (explicit):
# This repository only removed real tweet text from the current tip.
# Git history was NOT rewritten. Prior commits may still contain
# searchable original tweet text under data/analyzed, data/output, and
# data/seed. Treat historical blobs as residual exposure until a separate
# history-rewrite decision is made.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_BATCH_SIZE=20
